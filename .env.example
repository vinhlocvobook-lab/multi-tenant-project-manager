# Database Configuration (MariaDB)
DB_TYPE=mariadb
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=multi_tenant_db

# App Configuration
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=replace_this_with_a_secure_random_string_in_env
JWT_EXPIRATION=1d

# Multi-tenancy
TENANT_FILTER_ENABLED=true
